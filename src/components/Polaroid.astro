---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  caption: string;
  rotate?: number;
  width?: number;
  alt?: string;
}
const { src, caption, rotate = -3, width = 180, alt = "" } = Astro.props;
const wrapperStyle = `--polaroid-rotate: ${rotate}deg; width: ${width}px;`;
---

<div class="polaroid" style={wrapperStyle}>
  <div class="polaroid-photo">
    <Image src={src} alt={alt} width={width} densities={[1, 2]} />
  </div>
  <div class="polaroid-caption">{caption}</div>
</div>

<style>
  .polaroid {
    background: var(--polaroid-surface, var(--color-surface));
    padding: 8px 8px 14px;
    box-shadow:
      0 2px 5px oklch(0 0 0 / 0.1),
      0 6px 18px oklch(0 0 0 / 0.08);
    display: inline-block;
    transform: rotate(var(--polaroid-rotate, -3deg));
  }

  .polaroid-photo {
    aspect-ratio: 1 / 1.08;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .polaroid-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .polaroid-caption {
    font-family: var(--font-script);
    font-size: 16px;
    color: var(--color-margin-ink);
    text-align: center;
    line-height: 1.1;
    margin-block-start: 8px;
  }

  @media (forced-colors: active) {
    .polaroid {
      --polaroid-rotate: 0deg;
      forced-color-adjust: none;
    }
    .polaroid-caption {
      color: CanvasText;
    }
  }
</style>
