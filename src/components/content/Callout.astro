---
// Callout.astro — contextual aside with icon and accent-colored background
// type determines icon and color treatment
import Info from "phosphor-astro/Info.astro";
import Lightbulb from "phosphor-astro/Lightbulb.astro";
import Warning from "phosphor-astro/Warning.astro";
import WarningCircle from "phosphor-astro/WarningCircle.astro";

interface Props {
  type?: "note" | "tip" | "warning" | "important";
}

const { type = "note" } = Astro.props;
---

<aside class={`callout callout--${type}`}>
  <span class="callout-icon">
    {type === "note" && <Info width="16" height="16" aria-hidden="true" />}
    {type === "tip" && <Lightbulb width="16" height="16" aria-hidden="true" />}
    {type === "warning" && <Warning width="16" height="16" aria-hidden="true" />}
    {type === "important" && <WarningCircle width="16" height="16" aria-hidden="true" />}
  </span>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: var(--ma-narrow);
    padding: var(--ma-base);
    border-radius: 4px;
    margin-block: var(--ma-wide);
    background: var(--callout-bg, var(--color-accent-tint));
    border: 1px solid var(--callout-border, var(--color-accent));
    color: var(--color-text-primary);
  }

  .callout-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    color: var(--callout-icon-color, var(--color-accent));
    display: flex;
    align-items: flex-start;
  }

  .callout-body {
    flex: 1;
    min-width: 0;
  }

  .callout-body :global(p:first-child) {
    margin-top: 0;
  }

  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* warning type — warm orange */
  .callout--warning {
    --callout-bg: oklch(0.85 0.14 70 / 0.12);
    --callout-border: oklch(0.65 0.14 70);
    --callout-icon-color: oklch(0.65 0.14 70);
  }

  :global([data-theme="nightfall"]) .callout--warning {
    --callout-bg: oklch(0.30 0.10 70 / 0.20);
    --callout-border: oklch(0.65 0.14 70);
    --callout-icon-color: oklch(0.70 0.14 70);
  }

  /* important type — stronger accent tint */
  .callout--important {
    --callout-bg: color-mix(in oklch, var(--color-accent-tint) 150%, transparent);
  }
</style>
