---
// CodeGroup.astro — tabbed code blocks with per-tab copy button
// Uses static named slots (tab-0 through tab-7) and Astro.slots.has() to detect content
// Tab switching via inline script (no Svelte island — simple show/hide with ARIA)
interface Props {
  labels: string[];
}

const { labels } = Astro.props;

// Determine which slots have content (up to 8 tabs max)
const MAX_TABS = 8;

if (import.meta.env.DEV && labels.length > MAX_TABS) {
  // biome-ignore lint/suspicious/noConsole: intentional dev-only guard
  console.warn(
    `[CodeGroup] Only ${MAX_TABS} tabs are supported. Got ${labels.length} labels — extra labels will be ignored.`,
  );
}

const activeLabels = labels.slice(0, MAX_TABS);
const activeTabs = activeLabels
  .map((label, i) => ({ label, i }))
  .filter(({ i }) => Astro.slots.has(`tab-${i}`));

// Deterministic ID from labels — stable across dev hot-reloads for valid ARIA relationships
function hashLabels(items: string[]): string {
  const str = items.join("\x00");
  let h = 0x811c9dc5; // FNV-1a offset basis
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 0x01000193); // FNV prime
  }
  return (h >>> 0).toString(36);
}
const groupId = `cg-${hashLabels(activeLabels)}`;
---

<div class="code-group" data-group-id={groupId}>
  <div class="code-group-tabs" role="tablist" aria-label="Code examples">
    {activeTabs.map(({ label, i }, pos) => (
      <button
        class="code-group-tab"
        role="tab"
        aria-selected={pos === 0 ? 'true' : 'false'}
        aria-controls={`${groupId}-panel-${i}`}
        id={`${groupId}-tab-${i}`}
        tabindex={pos === 0 ? 0 : -1}
      >
        {label}
      </button>
    ))}
    <span class="code-group-indicator" aria-hidden="true"></span>
  </div>

  <div class="code-group-panels">
    {Astro.slots.has('tab-0') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-0`} aria-labelledby={`${groupId}-tab-0`}>
        <slot name="tab-0" />
      </div>
    )}
    {Astro.slots.has('tab-1') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-1`} aria-labelledby={`${groupId}-tab-1`} hidden>
        <slot name="tab-1" />
      </div>
    )}
    {Astro.slots.has('tab-2') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-2`} aria-labelledby={`${groupId}-tab-2`} hidden>
        <slot name="tab-2" />
      </div>
    )}
    {Astro.slots.has('tab-3') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-3`} aria-labelledby={`${groupId}-tab-3`} hidden>
        <slot name="tab-3" />
      </div>
    )}
    {Astro.slots.has('tab-4') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-4`} aria-labelledby={`${groupId}-tab-4`} hidden>
        <slot name="tab-4" />
      </div>
    )}
    {Astro.slots.has('tab-5') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-5`} aria-labelledby={`${groupId}-tab-5`} hidden>
        <slot name="tab-5" />
      </div>
    )}
    {Astro.slots.has('tab-6') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-6`} aria-labelledby={`${groupId}-tab-6`} hidden>
        <slot name="tab-6" />
      </div>
    )}
    {Astro.slots.has('tab-7') && (
      <div class="code-group-panel" role="tabpanel" id={`${groupId}-panel-7`} aria-labelledby={`${groupId}-tab-7`} hidden>
        <slot name="tab-7" />
      </div>
    )}
  </div>
</div>

<script>
  function initCodeGroups() {
    document.querySelectorAll<HTMLElement>('.code-group').forEach((group) => {
      if (group.dataset.cgInit === 'on') return; // idempotent across astro:page-load

      const tabs = group.querySelectorAll<HTMLElement>('[role="tab"]');
      const panels = group.querySelectorAll<HTMLElement>('[role="tabpanel"]');
      const indicator = group.querySelector<HTMLElement>('.code-group-indicator');

      // ── Sliding indicator ──────────────────────────────────────────────────

      function positionIndicator(index: number, animate: boolean) {
        if (!indicator) return;
        const tab = tabs[index];
        if (!tab) return;
        if (!animate) indicator.classList.add('is-snapping');
        indicator.style.transform = `translateX(${tab.offsetLeft}px) scaleX(${tab.offsetWidth})`;
        if (!animate) {
          void indicator.getBoundingClientRect(); // flush layout before re-enabling transitions
          indicator.classList.remove('is-snapping');
        }
      }

      // ── Tab switching ──────────────────────────────────────────────────────

      function activateTab(index: number) {
        tabs.forEach((t, i) => {
          const isActive = i === index;
          t.setAttribute('aria-selected', String(isActive));
          t.tabIndex = isActive ? 0 : -1;
        });
        panels.forEach((p, i) => {
          if (i === index) {
            p.removeAttribute('hidden');
          } else {
            p.setAttribute('hidden', '');
          }
        });
        positionIndicator(index, true);
      }

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activateTab(i));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowRight') {
            activateTab((i + 1) % tabs.length);
            (tabs[(i + 1) % tabs.length] as HTMLElement).focus();
          } else if (e.key === 'ArrowLeft') {
            const prev = (i - 1 + tabs.length) % tabs.length;
            activateTab(prev);
            (tabs[prev] as HTMLElement).focus();
          }
        });
      });

      // Initial placement: position under the active tab without animating in.
      const initialActive = Math.max(
        0,
        Array.from(tabs).findIndex((t) => t.getAttribute('aria-selected') === 'true'),
      );
      positionIndicator(initialActive, false);
      group.dataset.cgInit = 'on';

      // Reposition when the tabs row resizes (font load, container width change).
      if (indicator && 'ResizeObserver' in window) {
        const tabsRow = group.querySelector<HTMLElement>('.code-group-tabs');
        if (tabsRow) {
          const ro = new ResizeObserver(() => {
            const activeIndex = Array.from(tabs).findIndex(
              (t) => t.getAttribute('aria-selected') === 'true',
            );
            if (activeIndex >= 0) positionIndicator(activeIndex, false);
          });
          ro.observe(tabsRow);
        }
      }
    });
  }

  // First load: the module may evaluate after astro:page-load has fired.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCodeGroups, { once: true });
  } else {
    initCodeGroups();
  }

  // Re-initialize after each View Transition navigation
  document.addEventListener('astro:page-load', initCodeGroups);
</script>

<style>
  .code-group {
    margin-block: var(--ma-wide);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .code-group-tabs {
    position: relative;
    display: flex;
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
  }

  .code-group-tab {
    padding: var(--ma-narrow) var(--ma-base);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-size: var(--type-sm);
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
    margin-bottom: -1px;
  }

  .code-group-tab:hover {
    color: var(--color-text-primary);
  }

  /* No-JS fallback: keep the per-tab accent underline visible. */
  .code-group-tab[aria-selected="true"] {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
    font-weight: 500;
  }

  /* Once JS has placed the shared indicator, retire the per-tab underline. */
  .code-group[data-cg-init="on"] .code-group-tab[aria-selected="true"] {
    border-bottom-color: transparent;
  }

  .code-group-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
    border-radius: 2px;
  }

  .code-group-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 1px; /* reference width; scaleX in JS sets the real pixel width */
    height: 2px;
    background: var(--color-accent);
    transform-origin: left center;
    pointer-events: none;
    opacity: 0;
    transition:
      transform var(--motion-duration-smooth) var(--motion-easing-out-quart),
      opacity var(--motion-duration-quick) var(--motion-easing-out-quart);
  }

  .code-group[data-cg-init="on"] .code-group-indicator {
    opacity: 1;
  }

  /* Snap on first paint and on resize — no slide-from-default-position flash. */
  .code-group-indicator.is-snapping {
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .code-group-indicator {
      transition: opacity var(--motion-duration-quick) var(--motion-easing-out);
    }
  }

  /* Remove extra margin/border from EC code blocks inside panels */
  .code-group-panel :global(.expressive-code) {
    margin: 0;
  }

  .code-group-panel :global(.expressive-code .frame) {
    border-radius: 0;
    border: none;
    box-shadow: none;
  }

  .code-group-panel :global(.expressive-code pre) {
    margin: 0;
    border-radius: 0;
    border: none;
  }
</style>
