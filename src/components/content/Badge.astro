---
// Badge.astro — small inline label for technology names, status labels, etc.
interface Props {
  text: string;
  variant?: "default" | "accent" | "muted";
}

const { text, variant = "default" } = Astro.props;
---

<span class={`badge badge--${variant}`}>{text}</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--type-xs);
    font-family: var(--font-mono);
    padding: 2px var(--ma-narrow);
    border-radius: 3px;
    border: 1px solid var(--color-border);
    vertical-align: middle;
    white-space: nowrap;
    line-height: 1.4;
  }

  .badge--default {
    background: var(--color-accent-tint);
    color: var(--color-text-secondary);
  }

  .badge--accent {
    background: color-mix(in oklch, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border-color: color-mix(in oklch, var(--color-accent) 30%, transparent);
  }

  .badge--muted {
    background: var(--color-surface-alt);
    color: var(--color-text-secondary);
  }
</style>
