---
// src/components/Footer.astro
import LogoMark from "@components/LogoMark.astro";

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-row">
      <LogoMark size="sm" lift={true} />
      <nav aria-label="Social links" class="social-links">
        <a href="/rss.xml" aria-label="RSS feed" class="social-link social-link--rss">
          <svg width="18" height="18" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path data-rss="arc1" d="M12 19C12 14.8 9.2 12 5 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-rss="arc2" d="M19 19C19 10.6 13.4 5 5 5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-rss="dot" d="M5 19.01L5.01 18.9989" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://github.com/faoliveira" aria-label="GitHub" class="social-link social-link--github" rel="noopener noreferrer" target="_blank">
          <svg width="18" height="18" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path data-github="body" d="M16 22.0268V19.1568C16.0375 18.68 15.9731 18.2006 15.811 17.7506C15.6489 17.3006 15.3929 16.8902 15.06 16.5468C18.2 16.1968 21.5 15.0068 21.5 9.54679C21.4997 8.15062 20.9627 6.80799 20 5.79679C20.4558 4.5753 20.4236 3.22514 19.91 2.02679C19.91 2.02679 18.73 1.67679 16 3.50679C13.708 2.88561 11.292 2.88561 8.99999 3.50679C6.26999 1.67679 5.08999 2.02679 5.08999 2.02679C4.57636 3.22514 4.54413 4.5753 4.99999 5.79679C4.03011 6.81549 3.49251 8.17026 3.49999 9.57679C3.49999 14.9968 6.79998 16.1868 9.93998 16.5768C9.61098 16.9168 9.35725 17.3222 9.19529 17.7667C9.03334 18.2112 8.96679 18.6849 8.99999 19.1568V22.0268" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-github="tail" d="M9 20.0267C6 20.9999 3.5 20.0267 2 17.0267" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/faoliveira/" aria-label="LinkedIn" class="social-link social-link--linkedin" rel="noopener noreferrer" target="_blank">
          <svg width="18" height="18" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path data-linkedin="card" d="M21 8V16C21 18.7614 18.7614 21 16 21H8C5.23858 21 3 18.7614 3 16V8C3 5.23858 5.23858 3 8 3H16C18.7614 3 21 5.23858 21 8Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-linkedin="figure" d="M7 17V13.5V10" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-linkedin="connection" d="M11 17V13.75M11 10V13.75M11 13.75C11 10 17 10 17 13.75V17" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path data-linkedin="dot" d="M7 7.01L7.01 6.99889" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </nav>
    </div>
    <div class="footer-row footer-colophon">
      <small>
        <span>&copy; {year} &middot; built with</span>
        <svg class="colophon-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><path d="M6 1v3M10 1v3M14 1v3"/></svg>
      </small>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface-alt);
    padding-inline: clamp(var(--ma-base), 5vw, var(--ma-vast));
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--ma-narrow);
    padding-block: var(--ma-spacious) var(--ma-vast);
    max-width: var(--layout-max);
    margin-inline: auto;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-colophon {
    color: var(--color-text-secondary);
    font-size: var(--type-xs);
  }

  .footer-colophon small {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35em;
  }

  .colophon-icon {
    display: inline;
    vertical-align: -0.15em;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: var(--ma-base);
  }

  .social-link {
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    min-height: 44px;
    min-width: 44px;
    justify-content: center;
  }

  /* Color transition always present — only transform is gated on reduced-motion */
  .social-link {
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  @media (prefers-reduced-motion: no-preference) {
    .social-link {
      transition:
        color var(--motion-duration-quick) var(--motion-easing-out),
        transform var(--motion-duration-quick) var(--motion-easing-out);
    }
  }

  @media (hover: hover) {
    .social-link:hover {
      color: var(--color-accent);
    }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .social-link:hover {
      transform: translateY(-2px);
    }

    .social-link:active {
      transform: translateY(0);
    }
  }

  .social-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @keyframes rss-broadcast {
    0% { opacity: 0.15; }
    50% { opacity: 1; }
    100% { opacity: 0.15; }
  }

  @keyframes github-wag {
    0%   { transform: rotate(0deg); }
    20%  { transform: rotate(-18deg); }
    55%  { transform: rotate(12deg); }
    80%  { transform: rotate(-6deg); }
    100% { transform: rotate(0deg); }
  }

  @keyframes linkedin-connect {
    0%   { stroke-dashoffset: 60; }
    100% { stroke-dashoffset: 0; }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    /* data-rss attributes used instead of nth-child to survive SVG reordering */
    .social-link--rss:hover [data-rss="arc1"] {
      animation: rss-broadcast 1.4s ease-in-out infinite 0s;
    }

    .social-link--rss:hover [data-rss="arc2"] {
      animation: rss-broadcast 1.4s ease-in-out infinite 0.35s;
    }

    .social-link--github:hover [data-github="tail"] {
      transform-box: fill-box;
      transform-origin: 100% 100%;
      animation: github-wag 0.9s ease-in-out 1;
    }

    .social-link--linkedin:hover [data-linkedin="connection"] {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: linkedin-connect 0.9s ease-in-out 1 forwards;
    }
  }

  /* ── Accessibility: Forced Colors (Windows High Contrast) ── */
  /* border-top reinstated: tonal background fill is overridden by UA in forced-colors mode */
  @media (forced-colors: active) {
    footer {
      border-top: 1px solid ButtonText;
      background: Canvas;
    }
  }

</style>
