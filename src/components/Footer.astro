---
import LogoMark from "@components/LogoMark.astro";

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-row">
      <LogoMark size="sm" lift={true} />
      <nav aria-label="Social links" class="social-links">
        <a href="/rss.xml" class="social-link">rss</a>
        <span class="social-sep" aria-hidden="true">&middot;</span>
        <a href="https://github.com/faoliveira" class="social-link" rel="noopener noreferrer" target="_blank">github</a>
        <span class="social-sep" aria-hidden="true">&middot;</span>
        <a href="https://www.linkedin.com/in/faoliveira/" class="social-link" rel="noopener noreferrer" target="_blank">linkedin</a>
      </nav>
    </div>
    <div class="footer-row footer-colophon">
      <small>
        <span>&copy; {year} &middot; built with</span>
        <svg class="colophon-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><path d="M6 1v3M10 1v3M14 1v3"/></svg>
      </small>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface-alt);
    padding-inline: clamp(var(--ma-base), 5vw, var(--ma-vast));
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--ma-narrow);
    padding-block: var(--ma-base) var(--ma-broad);
    max-width: var(--layout-max);
    margin-inline: auto;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-colophon {
    color: var(--color-text-secondary);
    font-size: var(--type-xs);
  }

  .footer-colophon small {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35em;
  }

  .colophon-icon {
    display: inline;
    vertical-align: -0.15em;
  }

  .social-links {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    color: var(--color-text-secondary);
    font-size: var(--type-sm);
  }

  .social-link {
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--touch-target-min);
    min-height: var(--touch-target-min);
    padding-inline: 0.25em;
    text-decoration: none;
    transition:
      color var(--motion-duration-quick) var(--motion-easing-out),
      text-shadow var(--motion-duration-quick) var(--motion-easing-out);
  }

  @media (hover: hover) {
    .social-link:hover {
      color: var(--color-accent);
      text-shadow: 0 0 0.45em var(--color-accent-tint);
    }
  }

  .social-link:active {
    color: var(--color-accent-hover);
  }

  .social-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .social-sep {
    color: var(--color-text-tertiary);
    user-select: none;
  }

  /* Forced-colors mode overrides the tonal background fill, so reinstate a border. */
  @media (forced-colors: active) {
    footer {
      border-top: 1px solid ButtonText;
      background: Canvas;
    }
  }

</style>
