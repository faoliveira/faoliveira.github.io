---
// src/components/Nav.astro
import LogoMark from "@components/LogoMark.astro";
import NightfallToggle from "@components/NightfallToggle.astro";
import { isActivePath, NAV_ITEMS } from "@modules/navigation";

const currentPath = Astro.url.pathname;
---

<header transition:persist>
  <nav aria-label="Main navigation">
    <LogoMark />
    <div class="nav-right">
      <div class="links">
        {NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class="nav-link"
            aria-current={isActivePath(currentPath, item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
      <NightfallToggle />
    </div>
  </nav>
</header>

<script>
  import { isActivePath } from '@modules/navigation';

  document.addEventListener('astro:after-swap', () => {
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(link => {
      const href = link.getAttribute('href');
      if (!href) return;
      if (isActivePath(currentPath, href)) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  });
</script>

<style>
  header {
    padding-inline: clamp(var(--ma-wide), 5vw, var(--ma-breath));
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--ma-wide);
    max-width: var(--layout-max);
    margin-inline: auto;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--ma-base);
  }

  .links {
    display: flex;
    align-items: center;
    gap: var(--ma-wide);
  }

  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding-block: var(--ma-narrow);
    padding-inline: var(--ma-narrow);
    min-height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    inset-inline: var(--ma-narrow);
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .nav-link {
      transition: color var(--motion-duration-quick) var(--motion-easing-out);
    }

    .nav-link::after {
      transition: transform var(--motion-duration-normal) var(--motion-easing-out);
    }
  }

  /* Hover micro-indicator: underline grows in on non-active links */
  @media (hover: hover) {
    .nav-link:hover {
      color: var(--color-accent);
    }

    .nav-link:not([aria-current='page']):hover::after {
      transform: scaleX(1);
    }
  }

  /* Active link: solid underline, always visible */
  .nav-link[aria-current='page'] {
    color: var(--color-accent);
  }

  .nav-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* 480px: links fit at --ma-base gap down to 320px with 3 items at --type-sm */
  @media (max-width: 480px) {
    .links {
      gap: var(--ma-base);
    }
  }
</style>
