---
import TypeTag from "@components/TypeTag.astro";
import type { Post } from "@modules/content";
import { formatDate, toISODateString } from "@modules/content";

interface Props {
  post: Post;
  tapeSide?: "left" | "right";
  tapeTone?: "matcha" | "vermillion";
}

const { post, tapeSide = "left", tapeTone = "matcha" } = Astro.props;
const { title, description, date, type } = post.data;
const titleId = `featured-title-${post.id}`;
---

<a
  href={`/posts/${post.id}`}
  aria-labelledby={titleId}
  class:list={[
    "featured-card",
    "grain-surface",
    `featured-card--tape-${tapeSide}`,
    `featured-card--${tapeTone}`,
  ]}
>
  <span class="washi-tape" aria-hidden="true"></span>
  <span class="card-body">
    <span class="card-meta">
      {type && <TypeTag type={type} />}
      <span class="card-date-column">
        <time datetime={toISODateString(date)} class="card-date">{formatDate(date)}</time>
      </span>
    </span>
    <h3 class="card-title" id={titleId}>{title}</h3>
    {description && <span class="card-description">{description}</span>}
  </span>
</a>

<style>
  .featured-card {
    position: relative;
    display: flex;
    min-height: 100%;
    background: var(--color-surface-alt);
    padding: var(--ma-wide);
    border: 1px solid var(--color-border);
    border-radius: var(--ma-narrow);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    overflow: visible;
    isolation: isolate;
    transition:
      box-shadow var(--motion-duration-normal) var(--motion-easing-out),
      transform var(--motion-duration-normal) var(--motion-easing-out);
  }

  @media (hover: hover) {
    .featured-card:hover {
      box-shadow: var(--shadow-card-hover);
      transform: translateY(-2px);
    }
  }

  .featured-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card {
      transition: none;
    }
  }

  /* Tape is two stacked layers (day + night) that crossfade opacity on theme
     change, because gradients can't be @property-interpolated. The container
     holds positioning; ::before is the day tape, ::after is the nightfall tape. */
  .washi-tape {
    position: absolute;
    inset-block-start: -10px;
    z-index: 2;
    width: 90px;
    height: 18px;
    background: transparent;
    pointer-events: none;
  }

  .washi-tape::before,
  .washi-tape::after {
    content: "";
    position: absolute;
    inset: 0;
    transition: opacity var(--motion-duration-smooth) var(--motion-easing-out-quart);
  }

  .washi-tape::before {
    background: var(--tape-matcha-day);
    box-shadow: 0 1px 2px var(--tape-shadow-day);
    opacity: 1;
  }

  .washi-tape::after {
    background: var(--tape-matcha-night);
    box-shadow: 0 1px 2px var(--tape-shadow-night);
    opacity: 0;
  }

  .featured-card--vermillion .washi-tape::before {
    background: var(--tape-vermillion-day);
  }

  .featured-card--vermillion .washi-tape::after {
    background: var(--tape-vermillion-night);
  }

  :global([data-theme="nightfall"]) .washi-tape::before {
    opacity: 0;
  }

  :global([data-theme="nightfall"]) .washi-tape::after {
    opacity: 1;
  }

  .featured-card--tape-left .washi-tape {
    inset-inline-start: 40px;
    rotate: -6deg;
  }

  .featured-card--tape-right .washi-tape {
    inset-inline-end: 60px;
    rotate: 6deg;
  }

  @media (prefers-reduced-motion: reduce) {
    .washi-tape::before,
    .washi-tape::after {
      transition: none;
    }
  }

  .card-date-column,
  .card-body {
    min-width: 0;
  }

  .card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--ma-narrow);
    margin-block-end: var(--ma-narrow);
  }

  .card-title {
    font-size: var(--type-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-block-start: 0;
    line-height: var(--leading-lg);
  }

  .card-description {
    display: -webkit-box;
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-sm);
    margin-block-start: var(--ma-narrow);
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    display: inline-block;
    font-size: var(--type-xs);
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    line-height: var(--leading-xs);
    white-space: nowrap;
  }
</style>
