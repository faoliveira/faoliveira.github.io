---
// src/components/NightfallToggle.astro
---

<button
  id="nightfall-toggle"
  role="switch"
  aria-checked="false"
  aria-label="Nightfall mode"
>
  <svg
    class="chochin-wrap"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 26 32"
    width="18"
    height="22"
    fill="none"
    aria-hidden="true"
  >
    <!-- Inner glow: amber fill, day opacity:0, nightfall opacity:0.55 -->
    <circle class="inner-glow" cx="13" cy="19" r="8" fill="var(--glow-fill)" />
    <!-- Body fill: amber fill, day opacity:0, nightfall opacity:0.25 -->
    <circle class="body-fill" cx="13" cy="19" r="8" fill="var(--body-fill)" />
    <!-- Globe body: stroke only, currentColor -->
    <circle cx="13" cy="19" r="8" stroke="currentColor" stroke-width="2.0" />
    <!-- Ribs: 3 horizontal lines at 0.25 opacity -->
    <line x1="5.6" y1="16" x2="20.4" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.25" />
    <line x1="5" y1="19" x2="21" y2="19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.25" />
    <line x1="5.6" y1="22" x2="20.4" y2="22" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.25" />
    <!-- Flame group: day opacity:0, nightfall opacity:1 + flicker -->
    <g class="flame-group">
      <ellipse cx="13" cy="17" rx="2.5" ry="3.5" fill="var(--flame-color)" />
      <ellipse cx="13" cy="16.5" rx="1.2" ry="2" fill="var(--flame-inner)" />
    </g>
    <!-- Top cap -->
    <rect x="9" y="8" width="8" height="3" rx="1" fill="currentColor" />
    <!-- Cord -->
    <line x1="13" y1="4" x2="13" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    <!-- Hook -->
    <path d="M 13,4 C 13,1 20,1 20,3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
    <!-- Bottom cap -->
    <rect x="9" y="27" width="8" height="3" rx="1" fill="currentColor" />
  </svg>
</button>

<!-- Sync aria-checked immediately from the already-set data-theme, before module scripts run -->
<script is:inline>
  (function () {
    var btn = document.getElementById('nightfall-toggle');
    if (btn) {
      btn.setAttribute('aria-checked',
        document.documentElement.dataset.theme === 'nightfall' ? 'true' : 'false');
    }
  })();
</script>

<style>
  /* Component-level color tokens for chochin glow states.
     All amber values use hue 70 — the same hue family as --color-amber and --color-amber-muted
     in nightfall.css (Story 1.3). Glow chroma ranges 0.14-0.16 for visual intensity;
     --color-amber-muted (0.08) is the lower-chroma readability variant for text/surfaces. */
  :root {
    --glow-amber: oklch(0.75 0.14 70 / 0.5);
    --glow-amber-strong: oklch(0.75 0.14 70 / 0.8);
    --flame-color: oklch(0.80 0.16 70);
    --flame-inner: oklch(0.95 0.10 90 / 0.85);
    --body-fill: oklch(0.80 0.16 70 / 0.3);
    --glow-fill: oklch(0.80 0.16 70 / 0.4);
  }

  /* Hex fallback: browsers without oklch() support lose the glow effect without this */
  @supports not (color: oklch(0 0 0)) {
    :root {
      --glow-amber: rgba(201, 160, 58, 0.5);
      --glow-amber-strong: rgba(201, 160, 58, 0.8);
      --flame-color: #d4a83a;
      --flame-inner: rgba(246, 241, 200, 0.85);
      --body-fill: rgba(212, 168, 58, 0.3);
      --glow-fill: rgba(212, 168, 58, 0.4);
    }
  }

  button {
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 13px;
    transition:
      color var(--motion-duration-smooth) var(--motion-easing-out),
      filter var(--motion-duration-smooth) var(--motion-easing-out),
      opacity var(--motion-duration-quick) var(--motion-easing-out);
  }

  @media (hover: hover) {
    button:hover {
      opacity: 0.7;
    }
  }

  button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Swing pivot point at the hook/cord top */
  .chochin-wrap {
    transform-origin: top center;
    display: block;
  }

  /* Day mode: glow, fill, and flame layers hidden.
     Base transitions define EXTINGUISHING timing (nightfall → day):
     glow/fill fade first (no delay), flame fades second. */
  .inner-glow,
  .body-fill {
    opacity: 0;
    transition: opacity 0.2s ease-in;
  }

  .flame-group {
    opacity: 0;
    transition: opacity 0.18s ease-in;
  }

  /* Nightfall mode: warm amber glow, fill, and flame visible.
     Button filter ramps slowly to full glow over 600ms. */
  :global([data-theme="nightfall"]) button {
    color: var(--flame-color);
    filter: drop-shadow(0 0 10px var(--glow-amber));
    transition:
      color var(--motion-duration-smooth) var(--motion-easing-out),
      filter 0.6s ease-out,
      opacity var(--motion-duration-quick) var(--motion-easing-out);
  }

  @media (hover: hover) {
    :global([data-theme="nightfall"]) button:hover {
      opacity: 0.7;
      filter: drop-shadow(0 0 14px var(--glow-amber-strong));
    }
  }

  @media (forced-colors: active) and (hover: hover) {
    button:hover {
      filter: none;
      opacity: 1;
      color: Highlight;
    }
  }

  @media (forced-colors: active) {
    :global([data-theme="nightfall"]) button {
      filter: none;
    }
  }

  /* Nightfall layer LIGHTING stagger (day → nightfall):
     flame at ~30% (180ms), glow/fill at ~50% (300ms) */
  :global([data-theme="nightfall"]) .inner-glow {
    opacity: 0.55;
    transition: opacity 0.3s ease-out 300ms;
  }

  :global([data-theme="nightfall"]) .body-fill {
    opacity: 0.25;
    transition: opacity 0.3s ease-out 300ms;
  }

  :global([data-theme="nightfall"]) .flame-group {
    opacity: 1;
    transition: opacity 0.25s ease-out 180ms;
    animation: flameFlicker 2.5s ease-in-out infinite 0.5s;
  }

  /* Swing animation on click: spring-physics approximation */
  .chochin-wrap.swinging {
    animation: chochinSwing 600ms ease-out forwards;
  }

  @keyframes flameFlicker {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }

  @keyframes chochinSwing {
    0%   { transform: rotate(0deg); }
    15%  { transform: rotate(7deg); }
    35%  { transform: rotate(-4.5deg); }
    50%  { transform: rotate(2.5deg); }
    65%  { transform: rotate(-1.5deg); }
    80%  { transform: rotate(0.8deg); }
    100% { transform: rotate(0deg); }
  }

  /* Reduced motion: instant state swap — no swing, no stagger, no flicker */
  @media (prefers-reduced-motion: reduce) {
    button,
    :global([data-theme="nightfall"]) button {
      transition: none;
    }

    .chochin-wrap.swinging {
      animation: none;
    }

    .inner-glow,
    .body-fill,
    .flame-group {
      transition: none;
    }

    :global([data-theme="nightfall"]) .inner-glow,
    :global([data-theme="nightfall"]) .body-fill,
    :global([data-theme="nightfall"]) .flame-group {
      transition: none;
    }

    :global([data-theme="nightfall"]) .flame-group {
      animation: none;
    }
  }
</style>

<script>
  import { getTheme, toggleTheme } from '@modules/theme';

  const btn = document.getElementById('nightfall-toggle');
  const chochin = btn?.querySelector('.chochin-wrap');

  function syncState() {
    if (!btn) return;
    const isNightfall = getTheme() === 'nightfall';
    btn.setAttribute('aria-checked', String(isNightfall));
  }

  syncState();

  btn?.addEventListener('click', () => {
    document.documentElement.classList.add('theme-animated');
    toggleTheme();
    syncState();

    // Swing animation: remove first to allow restart on rapid clicks
    if (chochin) {
      chochin.classList.remove('swinging');
      void chochin.getBoundingClientRect(); // force reflow to restart animation
      chochin.classList.add('swinging');
      chochin.addEventListener('animationend', () => {
        chochin.classList.remove('swinging');
      }, { once: true });
    }
  });
</script>
