---
import FeaturedCard from "@components/FeaturedCard.astro";
import { getFeaturedPosts } from "@modules/content";

const posts = await getFeaturedPosts();
---

{posts.length > 0 && (
  <section class="featured-grid" aria-labelledby="featured-heading">
    <h2 id="featured-heading" class="section-label kb-section-label">Featured ——</h2>
    <div class="grid">
      {posts.map((post, index) => (
        <FeaturedCard
          post={post}
          tapeSide={index % 2 === 0 ? "left" : "right"}
          tapeTone={index % 2 === 0 ? "matcha" : "vermillion"}
        />
      ))}
    </div>
  </section>
)}

<style>
  .featured-grid {
    margin-block-end: var(--ma-spacious);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ma-wide);
    align-items: stretch;
  }

  .grid > :global(a) {
    width: 100%;
  }

  /* 768px = var(--bp-md) — CSS custom properties can't be used in media query expressions */
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
