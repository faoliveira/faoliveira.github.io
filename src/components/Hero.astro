---
---

<section class="hero" aria-labelledby="hero-heading">
  <h1 id="hero-heading">Seventeen tabs open and a restless dog.</h1>
  <div class="hero-rule" aria-hidden="true"></div>
  <p class="subtitle">Writing about projects, data, and things I noticed that I couldn't leave alone.</p>
</section>

<style>
  @keyframes hero-entrance {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero {
    padding-block-start: var(--ma-breath);
    padding-block-end: var(--ma-silence);
    text-align: center;
    animation: hero-entrance var(--motion-duration-reveal) var(--motion-easing-out) both;
  }

  .hero h1,
  .subtitle {
    max-width: 55ch;
    margin-inline: auto;
  }

  .hero h1 {
    font-size: clamp(var(--type-3xl), 5vw, var(--type-4xl));
    font-weight: 800;
    line-height: var(--leading-4xl);
    color: var(--color-text-primary);
  }

  .hero-rule {
    width: 3ch;
    height: 2px;
    background: var(--color-accent);
    margin-inline: auto;
    margin-block: var(--ma-base);
  }

  .subtitle {
    margin-block-start: 0;
    font-size: var(--type-md);
    color: var(--color-text-secondary);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      animation: none;
    }
  }
</style>
