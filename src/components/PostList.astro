---
import PostRow from "@components/PostRow.astro";
import { getPublishedPosts, type Post } from "@modules/content";

interface Props {
  posts?: Post[];
  showHeading?: boolean;
  headingText?: string;
  emptyStateText?: string;
  viewAllHref?: string;
}

const {
  posts: propPosts,
  showHeading = true,
  headingText = "All posts",
  emptyStateText = "Coming soon.",
  viewAllHref,
} = Astro.props;
const posts = propPosts ?? (await getPublishedPosts());
---

<section class="post-list">
  {showHeading && (
    <h2 class="section-label kb-section-label">{headingText}</h2>
  )}
  {posts.length > 0 ? (
    <ul class="posts" role="list">
      {posts.map((post) => (
        <li>
          <PostRow post={post} />
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty-state">{emptyStateText}</p>
  )}
  {viewAllHref && (
    <a href={viewAllHref} class="view-all">View all posts →</a>
  )}
</section>

<style>
  /* When PostList directly follows Hero (no FeaturedGrid between them), the
     hero's padding-block-end owns the pause; an extra top margin would double it. */
  :global(.hero + .post-list) {
    margin-block-start: 0;
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ma-base);
  }

  .posts li {
    min-height: 44px;
    display: flex;
    align-items: stretch;
  }

  .posts li > :global(a) {
    flex: 1;
  }

  .empty-state {
    color: var(--color-text-secondary);
  }

  .view-all {
    display: inline-block;
    margin-block-start: var(--ma-base);
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  @media (hover: hover) {
    .view-all:hover {
      color: var(--color-accent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .view-all {
      transition: none;
    }
  }
</style>
