---
interface Props {
  size?: number;
  color?: string;
  tongue?: boolean;
  class?: string;
}

const { size = 120, color = "currentColor", tongue = true, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 80 80"
  fill="none"
  class={className}
  aria-hidden="true"
>
  {/* Silhouette — body + head as one solid shape (fills with color) */}
  <g fill={color}>
    {/* body — sitting, haunches visible */}
    <path d="M 24 48 Q 20 44 22 38 Q 24 34 30 34 L 52 34 Q 60 34 62 40 Q 64 46 62 54 Q 62 60 56 61 L 30 61 Q 24 60 24 54 Z" />
    {/* front left leg */}
    <path d="M 32 58 Q 30 62 32 66 L 38 66 Q 40 62 38 58 Z" />
    {/* front right leg */}
    <path d="M 44 58 Q 42 62 44 66 L 50 66 Q 52 62 50 58 Z" />
    {/* head — round, slightly tilted */}
    <ellipse cx="30" cy="26" rx="14" ry="13" />
    {/* left ear — folded, classic JR */}
    <path d="M 19 16 Q 16 12 19 10 Q 24 11 24 18 Q 22 20 19 16 Z" />
    {/* right ear — flopped */}
    <path d="M 38 14 Q 42 11 44 14 Q 44 20 40 22 Q 37 21 38 14 Z" />
    {/* snout */}
    <ellipse cx="20" cy="30" rx="6" ry="4" />
    {/* tail — upright little flag */}
    <path d="M 60 38 Q 66 32 64 26 Q 70 28 68 36 Q 66 42 60 42 Z" />
  </g>
  {/* Reserved details (cut back to paper) */}
  {/* eye — reserved circle w/ dot */}
  <circle cx="32" cy="24" r="2" fill="var(--color-surface)" />
  <circle cx="32.4" cy="24.3" r="0.9" fill={color} />
  {/* nose highlight notch */}
  <circle cx="17.5" cy="28.5" r="0.6" fill="var(--color-surface)" opacity="0.6" />
  {/* mouth line — cut-back (invisible, preserved for canonical geometry) */}
  <path
    d="M 17 32 Q 21 34 25 32.5"
    stroke="white"
    stroke-width="0.9"
    stroke-linecap="round"
    fill="none"
    opacity="0"
  />
  {/* Head/body separation — a thin paper-colored line so body reads distinct */}
  <path
    d="M 23 36 Q 28 38 36 37"
    stroke="var(--color-surface)"
    stroke-width="1.2"
    stroke-linecap="round"
    fill="none"
    opacity="0.6"
  />
  {/* tongue */}
  {tongue && (
    <ellipse cx="19" cy="33.5" rx="1.4" ry="0.9" fill="var(--color-tongue)" />
  )}
  {/* chest/belly highlight — subtle */}
  <path
    d="M 38 52 Q 42 54 46 52"
    stroke="var(--color-surface)"
    stroke-width="1"
    opacity="0.4"
    fill="none"
  />
</svg>

<style>
  svg {
    display: inline-block;
    vertical-align: middle;
  }

  @media (forced-colors: active) {
    svg {
      forced-color-adjust: none;
    }
  }
</style>
