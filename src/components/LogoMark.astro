---
interface Props {
  size?: "sm" | "md";
  lift?: boolean;
  "aria-label"?: string;
}

const { size = "md", lift = false, "aria-label": ariaLabel = "fa. — home" } = Astro.props;
---

<a href="/" class:list={["logo", `logo--${size}`, { "logo--lift": lift }]} aria-label={ariaLabel}><span class="logo-text">fa</span><span class="logo-dot" aria-hidden="true">.</span></a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    font-family: var(--font-sans);
    text-decoration: none;
    /* Color transition always present — only transform is gated on reduced-motion */
    transition:
      color var(--motion-duration-quick) var(--motion-easing-out),
      opacity var(--motion-duration-quick) var(--motion-easing-out);
  }

  .logo--md {
    font-size: var(--type-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .logo--sm {
    font-size: var(--type-md);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .logo-dot {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo--lift {
      transition:
        color var(--motion-duration-quick) var(--motion-easing-out),
        opacity var(--motion-duration-quick) var(--motion-easing-out),
        transform var(--motion-duration-quick) var(--motion-easing-out);
    }
  }

  @media (hover: hover) {
    .logo:hover {
      opacity: 0.7;
    }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .logo--lift:hover {
      transform: translateY(-1px);
    }

    .logo--lift:active {
      transform: translateY(0);
      opacity: 0.5;
    }
  }

  @media (forced-colors: active) and (hover: hover) {
    .logo:hover {
      opacity: 1;
      color: Highlight;
    }
  }

  .logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
