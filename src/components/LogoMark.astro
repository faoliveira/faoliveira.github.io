---
// src/components/LogoMark.astro
interface Props {
  size?: "sm" | "md";
  lift?: boolean;
  "aria-label"?: string;
}

const {
  size = "md",
  lift = false,
  "aria-label": ariaLabel = "fa. — felipeo.me home",
} = Astro.props;

const isHomePage = Astro.url.pathname === "/";
---

<a href="/" class:list={["logo", `logo--${size}`, { "logo--lift": lift }]} aria-label={ariaLabel} aria-current={isHomePage ? 'page' : undefined}>fa.</a>

<style>
  .logo {
    font-family: var(--font-sans);
    font-size: var(--type-lg);
    text-decoration: none;
    /* Color transition always present — only transform is gated on reduced-motion */
    transition:
      color var(--motion-duration-quick) var(--motion-easing-out),
      opacity var(--motion-duration-quick) var(--motion-easing-out);
  }

  .logo--md {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .logo--sm {
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo--lift {
      transition:
        color var(--motion-duration-quick) var(--motion-easing-out),
        opacity var(--motion-duration-quick) var(--motion-easing-out),
        transform var(--motion-duration-quick) var(--motion-easing-out);
    }
  }

  @media (hover: hover) {
    .logo:hover {
      opacity: 0.7;
    }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .logo--lift:hover {
      transform: translateY(-1px);
    }

    .logo--lift:active {
      transform: translateY(0);
      opacity: 0.5;
    }
  }

  @media (forced-colors: active) and (hover: hover) {
    .logo:hover {
      opacity: 1;
      color: Highlight;
    }
  }

  .logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
