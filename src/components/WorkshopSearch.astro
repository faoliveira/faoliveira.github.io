---
import NunoDoodle from "@components/NunoDoodle.astro";
import WashiTape from "@components/WashiTape.astro";

const suggestions = ["esp32", "home server", "nuno"];

const nunoSearches = [
  "where is the ball",
  "cheese",
  "why did he leave",
  "sunbeam location: 3pm",
  "is it walk time",
  "the other sock",
  "bark frequency chart",
];
---

<div class="workshop-search">
  <div class="search-prompt">
    <span class="prompt-slash" aria-hidden="true">/</span>
    <input
      id="workshop-search-input"
      class="search-input"
      type="text"
      placeholder="type to search…"
      autocomplete="off"
      autocapitalize="off"
      aria-label="Search"
      aria-autocomplete="list"
      aria-controls="workshop-search-results"
      aria-describedby="workshop-search-status"
    />
    <span class="search-hint" aria-hidden="true">press / to focus</span>
    <button id="workshop-search-clear" class="search-clear" type="button" aria-label="Clear search">
      ESC ×
    </button>
  </div>

  <div id="workshop-search-results" class="search-results" role="region" aria-live="polite" hidden></div>
  <div id="workshop-search-status" class="search-status" aria-live="polite"></div>
</div>

<div class="search-suggestions">
  <p class="suggestions-label">or try one of these →</p>
  <div class="suggestions-list">
    {suggestions.map((s, i) => (
      <button
        type="button"
        class="suggestion-chip"
        data-suggestion={s}
		data-rotate={[-1, 0.5, 1][i % 3]}
      >
        <span class="suggestion-slash" aria-hidden="true">/</span> {s}
      </button>
    ))}
  </div>
</div>

<div class="nuno-search-card" hidden>
  <div class="nuno-search-tape">
<WashiTape width={72} height={18} rotate={4} tone="matcha"></WashiTape>
  </div>
  <div class="nuno-search-header">
    <NunoDoodle size={34} color="var(--color-text-secondary)" tongue={false}></NunoDoodle>
    <div class="nuno-search-header-text">
      <span class="nuno-search-title">Nuno tried these too.</span>
      <span class="nuno-search-subtitle">no results returned. he is undeterred.</span>
    </div>
  </div>
  <ul class="nuno-search-list">
    {nunoSearches.map((s) => (
      <li class="nuno-search-item">
        <span class="nuno-search-slash">/</span>
        <span class="nuno-search-query">{s}</span>
        <span class="nuno-search-count">0</span>
      </li>
    ))}
  </ul>
</div>

<script>
  import { initWorkshopSearch } from '@modules/search/workshop';

  const cleanup = initWorkshopSearch({
    input: document.getElementById('workshop-search-input') as HTMLInputElement | null,
    results: document.getElementById('workshop-search-results') as HTMLElement | null,
    status: document.getElementById('workshop-search-status') as HTMLElement | null,
    clearBtn: document.getElementById('workshop-search-clear') as HTMLButtonElement | null,
    hint: document.querySelector('.search-hint') as HTMLElement | null,
    suggestions: document.querySelector('.search-suggestions') as HTMLElement | null,
    nunoCard: document.querySelector('.nuno-search-card') as HTMLElement | null,
  });
  document.addEventListener('astro:before-swap', cleanup, { once: true });
</script>

<style>
  .workshop-search {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--ma-base) var(--ma-wide);
    cursor: text;
  }

  .workshop-search:hover,
  .workshop-search:focus-within {
    border-color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .workshop-search {
      transition: border-color var(--motion-duration-quick) var(--motion-easing-out);
    }
  }

  @media (forced-colors: active) {
    .workshop-search:hover,
    .workshop-search:focus-within {
      border-color: Highlight;
    }
  }

  .search-prompt {
    display: flex;
    align-items: center;
		gap: var(--ma-narrow);
    position: relative;
    z-index: 1;
  }

  .prompt-slash {
    font-family: var(--font-mono);
		font-size: var(--type-lg);
    color: var(--color-accent);
    line-height: 1;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-mono);
		font-size: var(--type-xl);
    color: var(--color-text-primary);
    padding: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .search-input::placeholder {
    color: var(--color-text-tertiary);
    opacity: 0.7;
  }

  .search-input:focus,
  .search-input:focus-visible {
    outline: none;
  }

  .search-clear {
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
		font-size: var(--type-xs);
    color: var(--color-text-tertiary);
    letter-spacing: 0.1em;
    padding: 6px 8px;
    min-height: 36px;
    white-space: nowrap;
  }

  .search-clear:hover {
    color: var(--color-text-primary);
  }

  .search-hint {
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    color: var(--color-text-tertiary);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .search-hint {
      display: none;
    }
  }

  .search-results {
    margin-top: var(--ma-base);
    max-height: 60vh;
    overflow-y: auto;
  }

  .search-results[hidden] {
    display: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .search-results[data-entering] {
      animation: workshop-results-in var(--motion-duration-normal) var(--motion-easing-out) both;
    }

    .search-results[data-entering] :global(.result-item) {
      animation: workshop-item-in var(--motion-duration-normal) var(--motion-easing-out) both;
      animation-delay: calc(var(--i, 0) * 40ms);
    }

    .search-results[data-entering] :global(.no-results),
    .search-results[data-entering] :global(.search-unavailable) {
      animation: workshop-item-in var(--motion-duration-normal) var(--motion-easing-out) both;
    }

    .nuno-search-card[data-entering] {
      animation: workshop-results-in var(--motion-duration-smooth) var(--motion-easing-out) both;
      animation-delay: 80ms;
    }

    @keyframes workshop-results-in {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
    }

    @keyframes workshop-item-in {
      from {
        opacity: 0;
        transform: translateY(4px);
      }
    }
  }

  .search-status {
    position: absolute;
    left: -9999px;
  }

  .search-results :global(.result-item) {
    display: block;
    padding: var(--ma-base) 0;
    border-block-start: 1px dotted var(--color-border);
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .search-results :global(.result-item:first-child) {
    border-block-start: none;
    padding-block-start: var(--ma-narrow);
  }

  @media (hover: hover) {
    .search-results :global(.result-item:hover) :global(.result-title) {
      color: var(--color-accent);
    }
  }

  .search-results :global(.result-item:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .search-results :global(.result-item[aria-selected="true"]) :global(.result-title) {
    color: var(--color-accent);
  }

  .search-results :global(.result-title) {
    font-family: var(--font-sans);
    font-size: var(--type-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-block-end: var(--ma-hair);
    color: inherit;
  }

  .search-results :global(.result-excerpt) {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .search-results :global(.result-excerpt mark) {
    background: var(--color-accent-tint);
    color: var(--color-text-primary);
    padding: 0 3px;
    border-radius: var(--radius-md);
  }

  .search-results :global(.no-results) {
    text-align: center;
    padding: var(--ma-wide) 0 var(--ma-narrow);
  }

  .search-results :global(.no-results p) {
    font-size: var(--type-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--ma-narrow);
  }

  .search-results :global(.no-results-links) {
    display: flex;
    gap: var(--ma-base);
    justify-content: center;
  }

  .search-results :global(.no-results-links a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .search-results :global(.search-unavailable) {
    text-align: center;
    padding: var(--ma-wide);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: var(--type-xs);
  }

  /* Suggestions */
  .search-suggestions {
    margin-top: 22px;
  }

  .search-suggestions[hidden] {
    display: none;
  }

  .suggestions-label {
    font-family: var(--font-hand);
		font-size: var(--type-xs);
    color: var(--color-text-tertiary);
    margin-bottom: 6px;
    letter-spacing: 0.02em;
  }

	.suggestions-list {
		display: flex;
		flex-wrap: nowrap;
		gap: var(--ma-thin) var(--ma-wide);
		align-items: baseline;
		overflow-x: auto;
		scrollbar-width: none;
		padding-block: 2px;
	}

	.suggestions-list::-webkit-scrollbar {
		display: none;
	}

  .suggestion-chip {
    font-family: var(--font-mono);
		font-size: var(--type-xs);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
		padding: 5px 10px;
    color: var(--color-text-secondary);
    cursor: pointer;
    letter-spacing: 0.04em;
    line-height: 1.5;
    box-decoration-break: clone;
    transition: border-color 140ms ease, color 140ms ease, transform 140ms ease;
  }

  .suggestion-slash {
    color: var(--color-accent);
  }

  .suggestion-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  .suggestion-chip:active {
    border-color: var(--color-accent-hover);
  }

  .suggestion-chip:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .suggestion-chip[data-rotate="-1"] { transform: rotate(-2deg); }
    .suggestion-chip[data-rotate="0.5"] { transform: rotate(1deg); }
    .suggestion-chip[data-rotate="1"] { transform: rotate(2deg); }
    .suggestion-chip:hover { transform: rotate(0deg) translateY(-1px); }
  }

  /* Nuno also searched card */
  .nuno-search-card {
		margin-top: var(--ma-broad);
		padding: var(--ma-wide) var(--ma-wide);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    position: relative;
  }


  .nuno-search-tape {
    position: absolute;
    top: -10px;
    right: 22px;
  }

  .nuno-search-header {
    display: flex;
    align-items: center;
		gap: var(--ma-narrow);
		margin-bottom: var(--ma-narrow);
  }

  .nuno-search-title {
    font-family: var(--font-hand);
		font-size: var(--type-xl);
    line-height: 1;
    display: block;
    color: var(--color-text-primary);
  }

  .nuno-search-subtitle {
    font-family: var(--font-mono);
		font-size: var(--type-xs);
    color: var(--color-text-tertiary);
    letter-spacing: 0.1em;
    margin-top: 2px;
    display: block;
  }

  .nuno-search-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
		gap: var(--ma-hair) var(--ma-wide);
  }

  .nuno-search-item {
    font-family: var(--font-mono);
		font-size: var(--type-xs);
    color: var(--color-text-primary);
    display: flex;
		gap: var(--ma-narrow);
    align-items: baseline;
  }

  .nuno-search-slash {
    color: var(--color-text-tertiary);
  }

  .nuno-search-query {
    text-decoration: line-through;
    text-decoration-color: var(--color-text-secondary);
    text-decoration-thickness: 1px;
  }

  .nuno-search-count {
    color: var(--color-text-tertiary);
    margin-left: auto;
  }

  @media (max-width: 480px) {
    .search-input {
		font-size: var(--type-md);
    }

    .nuno-search-list {
      grid-template-columns: 1fr;
    }

		.suggestion-chip {
			font-size: 0.625rem;
			padding: 3px 6px;
		}

		.suggestions-list {
			gap: var(--ma-thin) var(--ma-narrow);
		}
  }
</style>
