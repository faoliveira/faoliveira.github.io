---
import Pagination from "@components/Pagination.astro";
import PostList from "@components/PostList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedPosts, type Post } from "@modules/content";

const PAGE_SIZE = 10;
const allPosts = await getPublishedPosts();
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE) as Post[];
---

<BaseLayout title="Posts — felipeo.me">
  <header class="page-header">
    <h1>Posts</h1>
    <p class="tagline">Everything I couldn't leave alone, written down.</p>
  </header>
  <PostList posts={posts} showHeading={false} />
  {totalPages > 1 && (
    <Pagination currentPage={1} totalPages={totalPages} basePath="/posts" />
  )}
</BaseLayout>

<style>
  .page-header {
    padding-block-end: var(--ma-broad);
  }

  .page-header h1 {
    font-size: clamp(var(--type-3xl), 5vw, var(--type-4xl));
    font-weight: 800;
    line-height: var(--leading-4xl);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
  }

  .tagline {
    margin-block-start: var(--ma-narrow);
    font-size: var(--type-md);
    color: var(--color-text-secondary);
  }
</style>
