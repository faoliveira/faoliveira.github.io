---
import { render } from "astro:content";
import HeroImage from "@components/content/HeroImage.astro";
import DataEssayLayout from "@layouts/DataEssayLayout.astro";
import LogLayout from "@layouts/LogLayout.astro";
import PostLayout from "@layouts/PostLayout.astro";
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { getPublishedPosts } from "@modules/content";
import { SITE_URL } from "@modules/seo";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const isDataEssay = post.data.type === "data-essay";
const isProject = post.data.type === "project";
const isLog = post.data.type === "log";
const ogImage = post.data.og_image || `${SITE_URL}/og/${post.id}.png`;
---

{isDataEssay ? (
  /* Frontmatter hero src is a string path; local optimized assets via import() must be authored inline in MDX. */
  /* Two layout invocations on purpose: Astro registers the named slot at compile time
     whenever it sees `slot="hero"` in the JSX tree, so {cond && <X slot="hero" />} still
     makes Astro.slots.has("hero") return true in DataEssayLayout. The slot reference has
     to be absent from the rendered branch, not merely guarded by a falsy conditional. */
  post.data.hero ? (
    <DataEssayLayout
      title={post.data.title}
      description={post.data.description}
      date={post.data.date}
      type={post.data.type}
      image={ogImage}
    >
      <HeroImage
        slot="hero"
        src={post.data.hero.src}
        alt={post.data.hero.alt}
        caption={post.data.hero.caption}
        width={post.data.hero.width}
        height={post.data.hero.height}
      />
      <Content />
    </DataEssayLayout>
  ) : (
    <DataEssayLayout
      title={post.data.title}
      description={post.data.description}
      date={post.data.date}
      type={post.data.type}
      image={ogImage}
    >
      <Content />
    </DataEssayLayout>
  )
) : isProject ? (
  <ProjectLayout
    title={post.data.title}
    description={post.data.description}
    type="project"
    stack={post.data.stack}
    last_run={post.data.last_run}
    season={post.data.season}
    repo={post.data.repo}
    liveUrl={post.data.liveUrl}
    hasIsland={post.data.hasIsland}
    canvasMode={post.data.canvasMode}
    image={ogImage}
  >
    <Content />
  </ProjectLayout>
) : isLog ? (
  <LogLayout
    title={post.data.title}
    description={post.data.description}
    date={post.data.date}
    type="log"
    image={ogImage}
  >
    <Content />
  </LogLayout>
) : (
  <PostLayout
    title={post.data.title}
    description={post.data.description}
    date={post.data.date}
    type={post.data.type}
    reading={post.data.reading ?? (!post.data.type || post.data.type === "reflection")}
    toc={post.data.toc}
    headings={headings}
    image={ogImage}
  >
    <Content />
  </PostLayout>
)}
