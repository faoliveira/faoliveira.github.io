---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { Post } from "@modules/content";
import { getPostsByType, toISODateString } from "@modules/content";

const posts = await getPostsByType("log");

// Group posts by year (descending)
const byYear = new Map<number, Post[]>();
for (const post of posts) {
  const year = post.data.date.getUTCFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)?.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

function getExcerpt(post: Post): string {
  if (post.data.description) return post.data.description;
  const plain = (post.body ?? "")
    .replace(/```[\s\S]*?```/g, "") // strip fenced code blocks (backtick)
    .replace(/~~~[\s\S]*?~~~/g, "") // strip fenced code blocks (tilde)
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1") // strip links, keep text
    .replace(/^(import|export)\b.*$/gm, "") // strip MDX import/export lines
    .replace(/[#*_`~>!|]/g, "") // strip remaining markdown punctuation
    .replace(/\s+/g, " ")
    .trim();
  return plain.length > 160 ? `${plain.slice(0, 160).replace(/\s\S*$/, "")}…` : plain;
}
---

<BaseLayout
  title="Log — felipeo.me"
  description="Notes from the workbench. Short entries on what I'm building, fixing, and figuring out."
>
  <div class="log-listing">
    <header class="page-header">
      <h1 class="page-title">Log</h1>
      <p class="page-desc">
        Notes from the workbench. Short entries on what I'm building, fixing, and figuring out.
      </p>
    </header>

    <div class="log-list">
      {years.map((year) => {
        const yearPosts = byYear.get(year) ?? [];
        return (
          <section class="year-group">
            <div class="year-divider">
              <span class="year-label">{year}</span>
              <span class="year-rule" aria-hidden="true"></span>
            </div>
            {yearPosts.map((post, idx) => {
              const day = String(post.data.date.getUTCDate());
              const month = new Intl.DateTimeFormat("en-US", {
                month: "short",
                timeZone: "UTC",
              })
                .format(post.data.date)
                .toUpperCase();
              const isoDate = toISODateString(post.data.date);
              const excerpt = getExcerpt(post);
              return (
                <a
                  href={`/posts/${post.id}/`}
                  class:list={["entry-row", idx === 0 && "first-entry"]}
                >
                  <time class="entry-date" datetime={isoDate}>
                    <span class="entry-month">{month}</span>
                    <span class="entry-day">{day}</span>
                  </time>
                  <div class="entry-content">
                    <span class="entry-title">{post.data.title}</span>
                    {excerpt && <p class="entry-excerpt">{excerpt}</p>}
                  </div>
                </a>
              );
            })}
          </section>
        );
      })}

      {posts.length === 0 && (
        <p class="empty-state">Nothing logged yet.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .log-listing {
    margin-block-start: calc(var(--ma-spacious) - var(--ma-broad));
  }

  /* Page header */
  .page-header {
    margin-block-end: var(--ma-spacious);
  }

  .page-title {
    font-size: var(--type-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-block-end: var(--ma-narrow);
  }

  .page-desc {
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    max-width: 45ch;
  }

  /* Year divider */
  .year-divider {
    display: flex;
    align-items: center;
    gap: var(--ma-base);
    padding-block: var(--ma-wide);
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    color: var(--color-text-tertiary);
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .year-rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Entry row */
  .entry-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--ma-wide);
    padding-block: var(--ma-wide);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    align-items: start;
  }

  .first-entry {
    border-top: 1px solid var(--color-border);
  }

  /* Date column */
  .entry-date {
    display: flex;
    flex-direction: column;
    text-align: right;
    padding-right: var(--ma-base);
    border-right: 2px solid var(--color-accent-tint);
    gap: var(--ma-hair);
  }

  .entry-month {
    font-size: var(--type-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .entry-day {
    font-size: var(--type-3xl);
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1;
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  /* Content */
  .entry-title {
    display: block;
    font-size: var(--type-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  .entry-excerpt {
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-block-start: var(--ma-thin);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Hover states */
  @media (hover: hover) {
    .entry-row:hover .entry-title {
      color: var(--color-accent);
    }
  }

  /* Tablet (768–1023px) */
  @media (min-width: 768px) and (max-width: 1023px) {
    .entry-row {
      grid-template-columns: 80px 1fr;
      gap: var(--ma-base);
    }

    .entry-day {
      font-size: var(--type-2xl);
    }
  }

  /* Mobile (<768px) */
  @media (max-width: 767px) {
    .entry-row {
      display: block;
    }

    .entry-date {
      display: flex;
      flex-direction: row;
      align-items: baseline;
      gap: var(--ma-narrow);
      text-align: left;
      padding-right: 0;
      border-right: none;
      margin-block-end: var(--ma-narrow);
    }

    .entry-month {
      font-size: var(--type-sm);
    }

    .entry-day {
      font-size: var(--type-sm);
      font-family: var(--font-mono);
      font-weight: 500;
    }
  }

  .empty-state {
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    padding-block: var(--ma-wide);
  }
</style>
