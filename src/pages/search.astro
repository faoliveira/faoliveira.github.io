---
import MarginNote from "@components/MarginNote.astro";
import WorkshopSearch from "@components/WorkshopSearch.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Search — fa." description="All posts, one search box. Start typing.">
  <section class="search-page" aria-labelledby="search-heading">
    <div class="search-stage">

					<div class="search-hero">
<p class="section-label kb-section-label">Search the workshop ——</p>
						<h1 id="search-heading" class="search-title">
							Find something.
						</h1>
						<p class="search-subtitle">
							Title, tag, or a loose idea.
						</p>
						<MarginNote side="left">
							try a word.<br />
							any word.<br />
							<em>(even 'dog'.)</em>
						</MarginNote>
					</div>

      <div class="search-workshop">
        <WorkshopSearch />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .search-page {
    padding-block: var(--ma-spacious) var(--ma-breath);
  }

  .search-stage {
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
    padding-inline: clamp(var(--ma-base), 5vw, var(--ma-vast));
    position: relative;
  }

  .search-hero {
		margin-bottom: var(--ma-wide);
    position: relative;
  }



  .search-title {
    font-size: clamp(var(--type-2xl), 5vw, 40px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 6px;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .search-subtitle {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.55;
  }

  .search-hero :global(.margin-note) {
    position: absolute;
  }

  .search-hero :global(.margin-note--left) {
    left: 0;
    top: 0;
    transform: translateX(-100%) rotate(-3deg);
    padding-right: var(--ma-breath);
    transform-origin: top right;
  }

  .search-workshop {
		margin-top: var(--ma-wide);
  }

  @media (max-width: 1024px) {
    .search-hero :global(.margin-note) {
      position: static;
      transform: none;
      margin-bottom: 12px;
    }

  @media (max-width: 767.98px) {
    .search-hero :global(.margin-note) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .search-page {
      padding-block: var(--ma-broad) var(--ma-spacious);
    }

    .search-title {
      font-size: var(--type-xl);
    }

    .search-subtitle {
      font-size: var(--type-sm);
    }
  }
</style>
