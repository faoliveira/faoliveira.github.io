---
import nunoGardenSrc from "@assets/about/PXL_20221119_153439321.MP.jpg";
import nunoCouchSrc from "@assets/about/PXL_20240323_180449438.MP.jpg";
import felipeNunoSrc from "@assets/about/profile_avatar.webp";
import MarginNote from "@components/MarginNote.astro";
import Polaroid from "@components/Polaroid.astro";
import WashiTape from "@components/WashiTape.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { ABOUT_DESCRIPTION, SITE_URL } from "@modules/seo";
---

<BaseLayout title="About — fa." description={ABOUT_DESCRIPTION} image={`${SITE_URL}/og/about.png`}>
  <noscript slot="head"><style>.email-link { display: none !important; }</style></noscript>

  <div class="about-spread">
    <div class="marginalia">
      <div class="position-tl">
        <Polaroid
          src={nunoGardenSrc}
          caption="Nuno, the inspector"
          rotate={-6}
          width={175}
          alt="Nuno, a Jack Russell terrier, paws up on a garden fence with his tongue out"
        />
        <span class="tape-tl">
          <WashiTape tone="matcha" width={75} height={18} rotate={-5} />
        </span>
      </div>

      <div class="position-mr">
        <Polaroid
          src={nunoCouchSrc}
          caption="hawaii-core, SP"
          rotate={6}
          width={170}
          alt="Nuno asleep on a white couch wearing a striped collar"
        />
        <span class="tape-mr">
          <WashiTape tone="matcha" width={68} height={16} rotate={4} />
        </span>
      </div>

      <div class="position-br">
        <Polaroid
          src={felipeNunoSrc}
          caption="me & Nuno :)"
          rotate={4}
          width={185}
          alt="Felipe sitting cross-legged on a wood floor with Nuno on his lap, a bookshelf behind"
        />
        <span class="tape-br">
          <WashiTape tone="vermillion" width={70} height={16} rotate={7} />
        </span>
      </div>

      <div class="post-it">
        <strong>things I like:</strong><br />
        · Travelers notebooks<br />
        · DIY everything<br />
        · small things made by hand
        <span class="post-it-tape">
          <WashiTape tone="vermillion" width={50} height={14} rotate={3} />
        </span>
      </div>

      <span class="position-mn1">
        <MarginNote side="left" emphatic>
          the workshop is open →
        </MarginNote>
      </span>
    </div>

<article class="prose">
	<p class="section-label kb-section-label">About ——</p>
	<h1 class="sr-only">About</h1>

      <p>I don't have a five-year plan. I have seventeen browser tabs open and a dog who won't rest until someone throws the ball again.</p>

      <p>My name is Felipe Augusto — <span class="fa-highlight">FA</span>, like the note. Born in Fortaleza, living in São Paulo. I work as a data analyst. People either ask a lot of follow-up questions or immediately change the subject. Both make sense.</p>

      <p class="reveal">This site is inspired by the koubou, Japanese for workshop. A craftsperson's small space, organized for making rather than showing off. That felt like the right idea.</p>

      <p class="reveal">So this is where I write. About whatever is on my mind: projects I'm building, ideas that feel important at 11pm and somewhat revisable by morning, things I noticed and couldn't leave alone. Occasionally about typefaces, which is apparently who I am now.</p>

      <p class="reveal">If this sounds like your kind of thing — <a href="javascript:void(0)" class="email-link">write me</a><noscript> (enable JavaScript to reveal my email)</noscript>.</p>

      <p class="privacy-note">This site uses GoatCounter for analytics. No cookies, no personal data. <a href="/privacy/">Privacy policy.</a></p>
    </article>

    <div class="mobile-polaroid" aria-hidden="true">
      <Polaroid
        src={felipeNunoSrc}
        caption="me & Nuno :)"
        width={200}
      />
    </div>
  </div>
</BaseLayout>

<script>
	function initEmailLink() {
		const links = document.querySelectorAll('.email-link') as NodeListOf<HTMLAnchorElement>;
		if (links.length === 0) return;

		links.forEach(link => {
			if (link.dataset.emailDecoded) return;
			if (link.href.includes('mailto:')) {
				console.warn('Email obfuscation bypassed: link already contains mailto:');
				return;
			}
			const rot13 = (s: string) => s.replace(/[a-zA-Z]/g, c => {
				const base = c < 'a' ? 65 : 97;
				return String.fromCharCode(((c.charCodeAt(0) - base + 13) % 26) + base);
			});
			link.href = 'mailto:' + rot13('sryvcr@sryvcrb.zr');
			link.dataset.emailDecoded = 'true';
		});
	}
  // Run on initial load (MPA hard navigation) and on View Transition soft navigation
  initEmailLink();
  document.addEventListener('astro:page-load', initEmailLink);
</script>

<style>
  /* Full-bleed pattern: break out of #main-content's max-width + padding so the
     marginalia can sit in the wide gutters on either side of the 580px prose.
     The 100vw + calc(50% - 50vw) trick spans the full viewport regardless of
     ancestor constraints. */
  .about-spread {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    min-height: 920px;
  }

  /* Override the global .prose 62ch with the literal 580px the scrapbook composition needs. */
  .about-spread > .prose {
    max-width: 580px;
    margin-block: var(--ma-spacious) var(--ma-vast);
    margin-inline: auto;
    padding-inline: var(--ma-base);
    position: relative;
    z-index: 2;
  }

  /* Marginalia layer — absolute children positioned relative to .about-spread.
     Individual WashiTape spans carry their own aria-hidden. Polaroid alt text
     and MarginNote text are visible to assistive technology. */
  .marginalia {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .marginalia > * {
    position: absolute;
    pointer-events: auto;
  }

  /* Gutter offsets are clamp()-driven so polaroids stay flush to the page edge
     on narrow desktops without sliding off-canvas on wide ones. */
  .position-tl {
    left: clamp(20px, 4vw, 80px);
    top: 80px;
  }

  .position-mr {
    right: clamp(20px, 4vw, 80px);
    top: 340px;
  }

  .position-br {
    right: clamp(40px, 5vw, 120px);
    top: 680px;
  }

  .tape-tl {
    position: absolute;
    top: -8px;
    left: 60px;
  }

  .tape-mr {
    position: absolute;
    top: -8px;
    left: 50px;
  }

  .tape-br {
    position: absolute;
    top: -10px;
    right: 30px;
  }

  .post-it {
    left: clamp(40px, 6vw, 120px);
    top: 380px;
    width: 165px;
    background: var(--color-postit-yellow);
    padding: 16px 18px;
    transform: rotate(-3deg);
    box-shadow: var(--postit-shadow, 0 2px 4px oklch(0 0 0 / 0.08));
    font-family: var(--font-script);
    font-size: 18px;
    line-height: 1.3;
    color: var(--color-postit-ink, var(--color-margin-ink));
  }

  .post-it-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
  }

  .position-mn1 {
    left: clamp(40px, 6vw, 130px);
    top: 600px;
    width: 150px;
  }

  /* Narrow desktop (1024–1279px): scale marginalia down so they don't
     compete with the prose at the tightest gutter pinch (Sally's concern). */
  @media (min-width: 1024px) and (max-width: 1279.98px) {
    .marginalia > * {
      scale: 0.85;
    }
    .position-tl,
    .position-mn1,
    .post-it {
      transform-origin: top left;
    }
    .position-mr,
    .position-br {
      transform-origin: top right;
    }
  }

  /* Below 1024px the gutters can't fit the polaroids without colliding with
     prose. Hide marginalia and show a single inline polaroid below the prose. */
  .mobile-polaroid {
    display: none;
    text-align: center;
    margin-block-start: var(--ma-spacious);
    padding-inline: var(--ma-base);
  }

  @media (max-width: 1023.98px) {
    .marginalia {
      display: none;
    }
    .about-spread {
      min-height: 0;
    }
    .mobile-polaroid {
      display: block;
    }
  }

  /* Nightfall fixes: post-it ink must stay dark on the light-yellow surface,
     polaroid frame needs a distinct surface from the page background,
     and shadows need heavier opacity on the dark indigo surface. */
  :global(html[data-theme="nightfall"]) .about-spread {
    --color-postit-ink: oklch(0.35 0.04 40);
    --postit-shadow: 0 2px 6px oklch(0 0 0 / 0.25);
    --polaroid-surface: var(--color-surface-alt);
  }

  .fa-highlight {
    background: var(--color-accent-tint);
    padding-inline: 0.15em;
    border-radius: 2px;
    display: inline-block;
    transform: rotate(-1.5deg);
    transition: transform var(--motion-duration-quick) var(--motion-easing-out);
  }

  .fa-highlight:hover {
    transform: rotate(0deg);
  }

  @media (forced-colors: active) {
    .fa-highlight {
      background: transparent;
    }
    .post-it {
      transform: none;
      forced-color-adjust: none;
    }
  }

  .privacy-note {
    margin-block-start: var(--ma-broad);
    font-size: var(--type-sm);
		color: var(--color-text-secondary);
	}

	/* WCAG 2.5.8: expand touch targets to ≥44px without affecting visual layout.
	   line-height 1.7 × 16px ≈ 27px; padding adds 18px → 45px total. */
	.about-spread > .prose a {
		display: inline-block;
		padding-block: 9px;
		margin-block: -9px;
	}
