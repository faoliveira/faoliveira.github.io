---
import { Image } from "astro:assets";
import avatarSrc from "@assets/profile_avatar.webp";
import BaseLayout from "@layouts/BaseLayout.astro";
import { ABOUT_DESCRIPTION, SITE_URL } from "@modules/seo";
---

<BaseLayout title="About — fa." description={ABOUT_DESCRIPTION} image={`${SITE_URL}/og/about.png`}>
  <noscript slot="head"><style>.email-link { display: none !important; }</style></noscript>
  <article class="prose">
    <h1 class="sr-only">About</h1>

    <div class="avatar-sticker">
      <Image
        src={avatarSrc}
        alt="Felipe Oliveira"
        width={200}
        height={200}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
        class="profile-avatar"
      />
    </div>

    <p>I don't have a five-year plan. I have seventeen browser tabs open and a dog who won't rest until someone throws the ball again.</p>

    <p>My name is Felipe Augusto — <span class="fa-highlight">FA</span>, like the note. Born in Fortaleza, living in São Paulo. I work as a data analyst. People either ask a lot of follow-up questions or immediately change the subject. Both make sense.</p>

    <p class="reveal">This site is inspired by the koubou, Japanese for workshop. A craftsperson's small space, organized for making rather than showing off. That felt like the right idea.</p>

    <p class="reveal">So this is where I write. About whatever is on my mind: projects I'm building, ideas that feel important at 11pm and somewhat revisable by morning, things I noticed and couldn't leave alone. Occasionally about typefaces, which is apparently who I am now.</p>

    <p class="reveal">If this sounds like your kind of thing — <a href="javascript:void(0)" class="email-link">write me</a><noscript> (enable JavaScript to reveal my email)</noscript>.</p>

    <p class="privacy-note">This site uses GoatCounter for analytics. No cookies, no personal data. <a href="/privacy/">Privacy policy.</a></p>
  </article>
</BaseLayout>

<script>
  function initEmailLink() {
    const links = document.querySelectorAll('.email-link') as NodeListOf<HTMLAnchorElement>;
    if (links.length === 0) return;
    
    links.forEach(link => {
      if (link.href.includes('mailto:')) {
        console.warn('Email obfuscation bypassed: link already contains mailto:');
        return;
      }
      const rot13 = (s: string) => s.replace(/[a-zA-Z]/g, c => {
        const base = c < 'a' ? 65 : 97;
        return String.fromCharCode(((c.charCodeAt(0) - base + 13) % 26) + base);
      });
      link.href = 'mailto:' + rot13('sryvcr@sryvcrb.zr');
    });
  }
  // Run on initial load (MPA hard navigation) and on View Transition soft navigation
  initEmailLink();
  document.addEventListener('astro:page-load', initEmailLink);
</script>

<style>
  .avatar-sticker {
    float: inline-end;
    position: relative;
    isolation: isolate;
    width: 140px;
    height: 140px;
    margin-inline-start: var(--ma-base);
    margin-block-end: var(--ma-narrow);
    transform: rotate(2.5deg);
    transition: transform var(--motion-duration-quick) var(--motion-easing-out);
  }

  .avatar-sticker::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    transform: translate(4px, 4px);
    background-image: url("/textures/grain.webp");
    background-repeat: repeat;
    background-color: var(--color-accent-tint);
    mix-blend-mode: multiply;
    opacity: 0.6;
    z-index: -1;
    transition: transform var(--motion-duration-quick) var(--motion-easing-out),
                opacity var(--motion-duration-quick) var(--motion-easing-out);
  }

  .avatar-sticker:hover {
    transform: rotate(-1deg) translate(-1px, -2px);
  }

  .avatar-sticker:hover::after {
    transform: translate(6px, 6px);
    opacity: 0.75;
  }

  @media (prefers-color-scheme: dark) {
    .avatar-sticker::after {
      mix-blend-mode: screen;
      opacity: 0.4;
    }
    .avatar-sticker:hover::after {
      opacity: 0.6;
    }
  }

  .profile-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-surface);
    position: relative;
    z-index: 1;
  }

  @media (max-width: 640px) {
    .avatar-sticker {
      float: none;
      margin-inline: auto;
      margin-block: var(--ma-base);
    }
  }

  .fa-highlight {
    background: var(--color-accent-tint);
    padding-inline: 0.15em;
    border-radius: 2px;
    display: inline-block;
    transform: rotate(-1.5deg);
    transition: transform var(--motion-duration-quick) var(--motion-easing-out);
  }

  .fa-highlight:hover {
    transform: rotate(0deg);
  }

  @media (forced-colors: active) {
    .fa-highlight {
      background: transparent;
    }
  }

  .privacy-note {
    margin-block-start: var(--ma-broad);
    font-size: var(--type-sm);
    color: var(--color-text-tertiary);
  }
</style>
