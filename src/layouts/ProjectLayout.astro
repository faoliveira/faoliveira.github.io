---
import TypeTag from "@components/TypeTag.astro";
import type { PostType } from "@modules/content";
import { buildProjectStructuredData } from "@modules/seo";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  type: PostType;
  stack?: string[];
  last_run?: string;
  season?: string;
  repo?: string;
  liveUrl?: string;
  hasIsland?: boolean;
  canvasMode?: "interactive" | "prose";
  image?: string;
}

const {
  title,
  description,
  type,
  last_run,
  season,
  repo,
  liveUrl,
  hasIsland,
  canvasMode = "prose",
  image,
} = Astro.props;

const structuredData = buildProjectStructuredData({ title, description, repo, liveUrl });
---

<BaseLayout title={title} description={description} type="article" image={image}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <article class="project-article" data-post-type="project">

    <header class="project-header">
      <!-- LEFT: title group -->
      <div class="title-group">
        <TypeTag type={type} />
        <h1 class="project-title">{title}</h1>
        {description && <p class="project-description">{description}</p>}
      </div>

      <!-- RIGHT: HUD metadata -->
      <div class="hud-stats">
        {last_run && <span class="hud-item">{last_run}</span>}
        {season && <span class="hud-item">Season {season}</span>}
        {repo && (
          <a class="hud-link" href={repo} target="_blank" rel="noopener noreferrer">
            Source ↗<span class="sr-only"> (opens in new tab)</span>
          </a>
        )}
        {liveUrl && (
          <a class="hud-link" href={liveUrl} target="_blank" rel="noopener noreferrer">
            Live ↗<span class="sr-only"> (opens in new tab)</span>
          </a>
        )}
      </div>
    </header>

    <!-- Canvas Stage: outer = spacing, inner = visible container -->
    <div class="canvas-stage">
      <div class="canvas-container" data-canvas-mode={canvasMode}>
        {canvasMode === "prose" ? (
          <div class="prose"><slot /></div>
        ) : (
          <slot />
        )}
        {hasIsland && (
          <noscript>
            <p class="noscript-message">
              This project requires JavaScript to display its interactive content.
            </p>
          </noscript>
        )}
      </div>
    </div>

    <footer class="back-link-footer">
      <a href="/posts/" class="back-link">&larr; all posts</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .project-article {
    margin-block-start: calc(var(--ma-spacious) - var(--ma-broad));
  }

  /* Header: horizontal split */
  .project-header {
    max-width: min(1000px, 95vw);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--ma-broad);
    margin-block-end: var(--ma-wide);
  }

  .title-group {
    /* Optional: constrain width so it doesn't push HUD too far if title is long */
  }

  .project-title {
    font-size: var(--type-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-block-start: var(--ma-narrow);
    margin-block-end: 0;
  }

  .project-description {
    color: var(--color-text-secondary);
    max-width: 50ch;
    margin-block-start: var(--ma-narrow);
    margin-block-end: 0;
  }

  /* HUD: no box, no background — just text/links */
  .hud-stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--ma-thin);
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    color: var(--color-text-secondary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .hud-item {
    /* inherits font-family, font-size, color, white-space from .hud-stats */
  }

  .hud-link {
    display: inline-flex;
    align-items: center;
    gap: var(--ma-thin);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  .hud-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Canvas Stage */
  .canvas-stage {
    max-width: min(1000px, 95vw);
    margin-inline: auto;
    margin-block: var(--ma-spacious);
  }

  /* Canvas container: THE visible stage */
  .canvas-container {
    border-block-start: 2px solid var(--color-border);
    min-height: 400px;
    overflow: hidden;
  }

  .canvas-container[data-canvas-mode="prose"] {
    padding: var(--ma-wide);
  }

  .canvas-container[data-canvas-mode="prose"] .prose {
    max-width: 65ch;
    margin-inline: auto;
  }

  .canvas-container[data-canvas-mode="interactive"] {
    padding: 0;
  }

  .noscript-message {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 360px;
    font-family: var(--font-mono);
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    padding: var(--ma-wide);
    text-align: center;
  }

  /* Back Link */
  .back-link-footer {
    max-width: min(1000px, 95vw);
    margin-inline: auto;
    margin-block-start: var(--ma-spacious);
    padding-block-start: var(--ma-wide);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--type-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--motion-duration-quick) var(--motion-easing-out);
  }

  .back-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Hover states */
  @media (hover: hover) {
    .hud-link:hover {
      color: var(--color-accent-hover);
    }
    
    .back-link:hover {
      color: var(--color-accent);
    }
  }

  /* Mobile + tablet (<1024px): stack header */
  @media (max-width: 1023px) {
    .project-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--ma-base);
    }
    .hud-stats { align-items: flex-start; }
    .cta-row { justify-content: flex-start; }
    .project-title { font-size: var(--type-xl); }
  }
</style>
